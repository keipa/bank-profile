@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

<a href="#main-content" class="skip-link">Skip to main content</a>

<div class="page">
    <header class="navbar navbar-expand-lg navbar-transparent @(_isNavbarScrolled ? "navbar-scrolled" : "navbar-at-top")" role="banner">
        <div class="container-fluid">
            <a class="navbar-brand" href="/" aria-label="Bank Profiles - Home">
                Bank Profiles
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <NavMenu />
        </div>
    </header>

    <main id="main-content" class="container-fluid mt-4" role="main">
        <div class="content px-4">
            @(Body)
        </div>
    </main>

    <footer class="footer mt-5 py-3 bg-light" role="contentinfo">
        <div class="container text-center text-muted">
            <p>&copy; 2026 Bank Profiles. All rights reserved. | Data for informational purposes only.</p>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isNavbarScrolled;
    private DotNetObjectReference<MainLayout>? _layoutReference;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _layoutReference = DotNetObjectReference.Create(this);

            try
            {
                await JS.InvokeVoidAsync("themeHelper.applyThemeFromCookie");
            }
            catch (JSException ex)
            {
                Console.WriteLine($"Theme initialization failed: {ex.Message}");
            }

            try
            {
                await JS.InvokeVoidAsync("navbarHelper.initializeScrollTracking", _layoutReference);
            }
            catch (JSException ex)
            {
                Console.WriteLine($"Navbar scroll tracking failed: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public Task OnNavbarScrollChanged(bool isScrolled)
    {
        if (_isNavbarScrolled == isScrolled)
        {
            return Task.CompletedTask;
        }

        _isNavbarScrolled = isScrolled;
        StateHasChanged();
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (_layoutReference is null)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("navbarHelper.disposeScrollTracking");
        }
        catch (JSDisconnectedException)
        {
        }

        _layoutReference.Dispose();
    }
}
