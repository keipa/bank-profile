@inject ILocalizationService Localization
@inject IWebHostEnvironment Environment

<div class="collapse navbar-collapse" id="navbarNav">
    <div class="navbar-layout">
        <nav class="navbar-nav navbar-links" aria-label="Main navigation">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" aria-label="Home">
                @Localization.GetString("nav.home")
            </NavLink>

            <NavLink class="nav-link" href="banks" aria-label="Banks">
                @Localization.GetString("nav.banks")
            </NavLink>

            <NavLink class="nav-link" href="ratings" aria-label="Ratings">
                @Localization.GetString("nav.ratings")
            </NavLink>

            <NavLink class="nav-link" href="contacts" aria-label="Contacts">
                @Localization.GetString("nav.contacts")
            </NavLink>

            <NavLink class="nav-link" href="about" aria-label="About">
                @Localization.GetString("nav.about")
            </NavLink>

            <NavLink class="nav-link" href="feedback" aria-label="Feedback">
                @Localization.GetString("nav.feedback")
            </NavLink>

            <NavLink class="nav-link" href="metric-suggestions" aria-label="Metric suggestions">
                @Localization.GetString("nav.metricSuggestions")
            </NavLink>

            <NavLink class="nav-link" href="submit-bank" aria-label="Submit new bank">
                @Localization.GetString("nav.submitBank")
            </NavLink>

            <NavLink class="nav-link" href="admin/bank-submissions" aria-label="Bank submissions admin">
                @Localization.GetString("nav.bankSubmissions")
            </NavLink>

            @if (Environment.IsDevelopment())
            {
                <NavLink class="nav-link" href="admin/feedback" aria-label="Feedback moderation admin">
                    @Localization.GetString("nav.feedbackModeration")
                </NavLink>
            }
        </nav>

        <div class="navbar-controls" role="group" aria-label="Language and theme controls">
            <LanguageSelector CompactMode="true" />
            <ThemeToggle />
        </div>
    </div>
</div>
