@page "/contacts"
@inject ILocalizationService Localization

<PageTitle>@Localization.GetString("page.contacts.pageTitle")</PageTitle>

<h1><i class="fas fa-envelope" aria-hidden="true"></i> @Localization.GetString("page.contacts.title")</h1>

<div class="row mt-4">
    <div class="col-md-6">
        <section class="card" aria-labelledby="contact-info-heading">
            <div class="card-body">
                <h2 id="contact-info-heading" class="card-title h5">@Localization.GetString("page.contacts.getInTouch")</h2>
                <p>@Localization.GetString("page.contacts.description")</p>
                
                <address class="contact-info mt-4">
                    <p><i class="fas fa-envelope" aria-hidden="true"></i> <a href="mailto:info@bankprofiles.com">info@bankprofiles.com</a></p>
                    <p><i class="fas fa-phone" aria-hidden="true"></i> <a href="tel:+18002265463">+1-800-BANK-INFO</a></p>
                    <p><i class="fas fa-map-marker-alt" aria-hidden="true"></i> 123 Finance Street, New York, NY 10001</p>
                </address>

                <div class="mt-4">
                    <h3 class="h6">@Localization.GetString("page.contacts.businessHours")</h3>
                    <p>@Localization.GetString("page.contacts.hours")</p>
                </div>
            </div>
        </section>
    </div>
    <div class="col-md-6">
        <aside class="card">
            <div class="card-body">
                <h2 class="card-title h5">@Localization.GetString("page.contacts.quickLinks")</h2>
                <nav aria-label="Quick navigation links">
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="/banks"><i class="fas fa-building" aria-hidden="true"></i> @Localization.GetString("page.contacts.browseBanks")</a></li>
                        <li class="mb-2"><a href="/ratings"><i class="fas fa-star" aria-hidden="true"></i> @Localization.GetString("page.contacts.compareRatings")</a></li>
                        <li class="mb-2"><a href="/about"><i class="fas fa-info-circle" aria-hidden="true"></i> @Localization.GetString("page.contacts.aboutUs")</a></li>
                    </ul>
                </nav>

                <div class="alert alert-info mt-4" role="alert">
                    <strong>@Localization.GetString("page.contacts.noteTitle")</strong> @Localization.GetString("page.contacts.noteText")
                </div>
            </div>
        </aside>
    </div>
</div>
