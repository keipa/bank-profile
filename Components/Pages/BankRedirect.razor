@page "/bank/{BankCode}"
@rendermode InteractiveServer

@if (_loading)
{
    <div class="text-center p-5">
        <div class="spinner-border"></div>
        <p class="mt-3">Redirecting...</p>
    </div>
}
else if (_bank == null)
{
    <div class="alert alert-warning">Bank not found</div>
}

@code {
    [Parameter] public string BankCode { get; set; } = "";
    private BankProfile? _bank;
    private bool _loading = true;

    [Inject] private IBankDataService BankService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _bank = await BankService.GetBankByCodeAsync(BankCode);
        if (_bank != null)
        {
            // Redirect to the new country-based URL
            Navigation.NavigateTo($"/{_bank.CountryCode}/{_bank.BankCode}", forceLoad: false);
        }
        _loading = false;
    }
}
