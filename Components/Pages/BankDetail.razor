@page "/{CountryCode}/{BankCode}"
@implements IAsyncDisposable
@using System.Text.Json
@using BankProfiles.Web.Application.Features.BankProfiles.Services
@using BankProfiles.Web.Application.Interfaces.Services.BankProfiles
@using BankProfiles.Web.Application.Interfaces.Services.Localization
@using BankProfiles.Web.Application.Interfaces.Services.Ratings
@using BankProfiles.Web.Domain.BankProfiles
@using BankProfiles.Web.Domain.Common.Metrics
@inject ILocalizationService Localization
@inject IBankDataService BankDataService
@inject IRatingService RatingService
@inject IViewCountService ViewCountService
@inject ICountryService CountryService
@inject IBankMetricsExtractorService MetricsExtractor
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>@_bank?.BankName ?? @Localization.GetString("page.bankDetail.pageTitle")</PageTitle>

@if (_loading)
{
    <div role="status" aria-label="Loading bank details">
        <span class="visually-hidden">Loading bank information...</span>
        <BankDetailSkeleton />
    </div>
}
else if (_bank == null)
{
    <div class="alert alert-warning" role="alert">@Localization.GetString("page.bankDetail.notFound")</div>
}
else
{
    @* Aurora Mesh Background *@
    <AuroraBackground />

    @* Scene Navigation Dots (left side) *@
    <nav class="scene-dots" aria-label="Scene navigation">
        @for (var i = 0; i < _sceneLabels.Count; i++)
        {
            var idx = i;
            <button class="scene-dot @(i == _activeSceneIndex ? "active" : "")"
                    data-label="@_sceneLabels[i]"
                    aria-label="Go to @_sceneLabels[i]"
                    @onclick="() => ScrollToScene(idx)"></button>
        }
    </nav>

    @* Scene HUD (top right) *@
    <div class="scene-hud" aria-live="polite" aria-atomic="true">
        <span class="scene-hud-label">Scene</span>
        <span id="scene-hud-text" class="scene-hud-counter">@(_activeSceneIndex + 1) / @_sceneLabels.Count</span>
        <div class="scene-hud-bar-track">
            <div id="scene-hud-bar" class="scene-hud-bar"></div>
        </div>
    </div>

    @* Scene Scroll Container *@
    <div class="scene-scroll-container" style="--bank-accent: @(_bank.Theme?.AccentColor ?? "#007AFF")">

        @* ─── Scene 1: Hero ─── *@
        <section class="scene scene-hero" data-scene-title="@_bank.BankName">
            <div class="scene-inner">
                <header class="bank-header-apple" role="banner">
                    <h1 class="bank-name-apple">@_bank.BankName</h1>
                    @if (!string.IsNullOrEmpty(_bank.LegalName) && _bank.LegalName != _bank.Name)
                    {
                        <p class="bank-legal-name">@_bank.LegalName</p>
                    }
                    @if (_bank.Metadata?.LastReviewed != null)
                    {
                        <div class="last-reviewed-compact">
                            <i class="fas fa-check-circle"></i>
                            Updated @GetTimeAgo(_bank.Metadata.LastReviewed.Value)
                        </div>
                    }
                </header>

                @* Card Designs Widget *@
                @if (_cardDesigns?.Count > 0)
                {
                    <CardDesignWidget CardDesigns="_cardDesigns" OnOpenGallery="OpenCardGallery" />
                }

                @* Overview & Ratings tiles in hero scene *@
                @if (_groupedMetrics != null && _groupedMetrics.TryGetValue(BankMetricsExtractorService.OverviewRatingsSectionKey, out var overviewMetrics))
                {
                    <TileSection SectionKey="@BankMetricsExtractorService.OverviewRatingsSectionKey"
                                 Title="@GetLocalizedSectionTitle(BankMetricsExtractorService.OverviewRatingsSectionKey)"
                                 Metrics="@overviewMetrics"
                                 Icon="@GetSectionIcon(BankMetricsExtractorService.OverviewRatingsSectionKey)"
                                 ShowProgressBars="true"
                                 BankCode="@BankCode"
                                 AccentColor="@(_bank.Theme?.AccentColor ?? "#007AFF")" />
                }
            </div>

            @if (HasNextScene(0))
            {
                <button type="button"
                        class="scene-next-arrow"
                        aria-label="Scroll to next section"
                        @onclick="() => ScrollToNextScene(0)">
                    <span class="scene-next-arrow-icon" aria-hidden="true">
                        <i class="fas fa-chevron-down"></i>
                        <i class="fas fa-chevron-down"></i>
                    </span>
                </button>
            }
        </section>

        @* ─── Scene 2: Feature Matrix ─── *@
        @if (_groupedMetrics != null && _groupedMetrics.TryGetValue(BankMetricsExtractorService.FeatureMatrixSectionKey, out var featureMatrixMetrics) && featureMatrixMetrics.Count > 0)
        {
            <section class="scene scene-feature-matrix" data-scene-title="@Localization.GetString("page.bankDetail.featureMatrix.sectionTitle")">
                <div class="scene-inner">
                    <div class="scene-section-header">
                        <i class="fas fa-th scene-section-icon" aria-hidden="true"></i>
                        <h2 class="scene-section-title">@Localization.GetString("page.bankDetail.featureMatrix.sectionTitle")</h2>
                    </div>
                    <FeatureMatrixSection Metrics="@featureMatrixMetrics"
                                         BankCode="@BankCode"
                                         AccentColor="@(_bank.Theme?.AccentColor ?? "#007AFF")" />
                </div>

                @if (HasNextScene(1))
                {
                    <button type="button"
                            class="scene-next-arrow"
                            aria-label="Scroll to next section"
                            @onclick="() => ScrollToNextScene(1)">
                        <span class="scene-next-arrow-icon" aria-hidden="true">
                            <i class="fas fa-chevron-down"></i>
                            <i class="fas fa-chevron-down"></i>
                        </span>
                    </button>
                }
            </section>
        }

        @* ─── Scenes 3-6: Metric Sections ─── *@
        @if (_groupedMetrics != null)
        {
            var metricGroups = _groupedMetrics
                .Where(g => g.Key != BankMetricsExtractorService.OverviewRatingsSectionKey 
                         && g.Key != BankMetricsExtractorService.FeatureMatrixSectionKey)
                .ToList();

            @for (var metricIndex = 0; metricIndex < metricGroups.Count; metricIndex++)
            {
                var group = metricGroups[metricIndex];
                var sceneIndex = metricIndex + 2; // +2 to account for hero (0) and feature matrix (1)

                <section class="scene scene-metrics" data-scene-title="@GetLocalizedSectionTitle(group.Key)">
                    <div class="scene-inner">
                        <div class="scene-section-header">
                            <i class="@GetSectionIcon(group.Key) scene-section-icon" aria-hidden="true"></i>
                            <h2 class="scene-section-title">@GetLocalizedSectionTitle(group.Key)</h2>
                        </div>
                        <TileSection SectionKey="@group.Key"
                                     Title=""
                                     Metrics="@group.Value"
                                     Icon=""
                                     ShowProgressBars="@ShouldShowProgressBars(group.Key)"
                                     BankCode="@BankCode"
                                     AccentColor="@(_bank.Theme?.AccentColor ?? "#007AFF")" />
                    </div>

                    @if (HasNextScene(sceneIndex))
                    {
                        <button type="button"
                                class="scene-next-arrow"
                                aria-label="Scroll to next section"
                                @onclick="() => ScrollToNextScene(sceneIndex)">
                            <span class="scene-next-arrow-icon" aria-hidden="true">
                                <i class="fas fa-chevron-down"></i>
                                <i class="fas fa-chevron-down"></i>
                            </span>
                        </button>
                    }
                </section>
            }
        }

        @* ─── Scene 6: Charts & Analytics ─── *@
        <section class="scene scene-charts" data-scene-title="Charts & Analytics">
            <div class="scene-inner">
                <div class="scene-section-header">
                    <i class="fas fa-chart-line scene-section-icon" aria-hidden="true"></i>
                    <h2 class="scene-section-title">Charts & Analytics</h2>
                </div>

                <div class="charts-grid">
                    <div class="chart-card">
                        <ErrorBoundary>
                            <ChildContent>
                                <RatingChart BankCode="@BankCode" />
                            </ChildContent>
                            <ErrorContent>
                                <div class="alert alert-danger">Failed to load rating chart.</div>
                            </ErrorContent>
                        </ErrorBoundary>
                    </div>
                    <div class="chart-card">
                        <ErrorBoundary>
                            <ChildContent>
                                <ViewsChart BankCode="@BankCode" />
                            </ChildContent>
                            <ErrorContent>
                                <div class="alert alert-danger">Failed to load view history chart.</div>
                            </ErrorContent>
                        </ErrorBoundary>
                    </div>
                </div>

                @if (_bank.Transactions?.OutgoingDestinations?.Count > 0)
                {
                    <div class="transaction-roadmap-section mt-4">
                        <h2 class="tile-section-header">
                            <i class="fas fa-route section-icon"></i>
                            @Localization.GetString("page.bankDetail.transactionRoutes.sectionTitle")
                        </h2>
                        <TransactionRoadmapCard OriginCountry="@_bank.HeadquartersCountry"
                                                DestinationCountries="@_transactionDestinations"
                                                OnOpen="OpenTransactionRoadmap" />
                    </div>
                }

                @* Quick Actions *@
                <div class="scene-quick-actions">
                    <a href="/@(_bank.CountryCode ?? CountryCode)/@BankCode/rate" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-star me-1"></i> @Localization.GetString("bank.rateThisBank")
                    </a>
                    @if (!string.IsNullOrEmpty(_bank.WebsiteUrl))
                    {
                        <a href="@_bank.WebsiteUrl" target="_blank" rel="noopener noreferrer"
                           class="btn btn-primary btn-lg">
                            <i class="fas fa-globe"></i> Visit Website
                        </a>
                    }
                    <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="ToggleBankJsonPopup">
                        <i class="fas fa-code me-1"></i> @(_isBankJsonPopupVisible ? "Hide JSON" : "Show JSON")
                    </button>
                    @if (_viewCount > 0)
                    {
                        <div class="view-count-display">
                            <i class="fas fa-eye"></i> @_viewCount views
                        </div>
                    }
                </div>
            </div>
        </section>

    </div>

    @if (_isBankJsonPopupVisible)
    {
        <div class="bank-json-popup-backdrop" @onclick="CloseBankJsonPopup">
            <div class="bank-json-popup" role="dialog" aria-modal="true" aria-labelledby="bank-json-title" @onclick:stopPropagation="true">
                <div class="bank-json-popup-header">
                    <h3 id="bank-json-title" class="bank-json-popup-title">Serialized Bank JSON</h3>
                    <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="CloseBankJsonPopup"></button>
                </div>
                <pre class="bank-json-popup-content"><code>@_bankSerializedJson</code></pre>
            </div>
        </div>
    }

    @* Metric Detail Modal *@
    <MetricDetailModal />

    <TransactionRoadmapModal IsVisible="@_isRoadmapModalVisible"
                             OriginCountry="@(_bank.HeadquartersCountry)"
                             DestinationCountries="@_transactionDestinations"
                             OnClose="CloseTransactionRoadmapAsync" />

    @* Card Designs Gallery Modal *@
    <CardDesignGallery IsVisible="@_isCardGalleryVisible"
                       CardDesigns="@_cardDesigns"
                       OnClose="CloseCardGallery" />
}

<style>
    .bank-header-apple {
        text-align: center;
        padding: 40px 20px;
        position: relative;
        z-index: 10;
    }

    .bank-name-apple {
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: 56px;
        font-weight: 700;
        letter-spacing: -1.5px;
        color: var(--text-primary);
        margin: 0 0 12px 0;
        line-height: 1.1;
    }

    .bank-legal-name {
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: 18px;
        font-weight: 400;
        color: var(--text-secondary);
        margin: 0 0 12px 0;
    }

    .last-reviewed-compact {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: var(--text-secondary);
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
    }

    .last-reviewed-compact i {
        color: #34C759;
    }

    .view-count-display {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 12px;
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: 16px;
        font-weight: 500;
        color: var(--text-primary);
    }

    .bank-json-popup-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1200;
        background: rgba(0, 0, 0, 0.68);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .bank-json-popup {
        width: min(980px, 100%);
        max-height: min(80vh, 860px);
        background: rgba(12, 16, 26, 0.95);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 14px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .bank-json-popup-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    }

    .bank-json-popup-title {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
        color: #f8f9fa;
    }

    .bank-json-popup-content {
        margin: 0;
        padding: 16px;
        overflow: auto;
        color: #d9f3ff;
        font-size: 13px;
        line-height: 1.45;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        white-space: pre;
        tab-size: 2;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .bank-name-apple {
            font-size: 36px;
        }

        .bank-json-popup-backdrop {
            padding: 12px;
        }

        .bank-json-popup {
            max-height: 86vh;
        }
    }
</style>

@code {
    private static readonly JsonSerializerOptions BankJsonSerializerOptions = new()
    {
        WriteIndented = true
    };

    [Parameter] public string CountryCode { get; set; } = default!;
    [Parameter] public string BankCode { get; set; } = "";
    private BankProfile? _bank;
    private CountryInfo? _countryInfo;
    private long _viewCount;
    private double _overallRating;
    private int _totalRatings;
    private bool _loading = true;
    private Dictionary<string, List<MetricDto>>? _groupedMetrics;
    private List<string> _transactionDestinations = new();
    private bool _isRoadmapModalVisible;
    private bool _isBankJsonPopupVisible;
    private bool _isCardGalleryVisible;
    private List<CardDesign>? _cardDesigns;
    private string _bankSerializedJson = string.Empty;
    private int _activeSceneIndex;
    private DotNetObjectReference<BankDetail>? _sceneRef;
    private List<string> _sceneLabels = new();

    protected override async Task OnInitializedAsync()
    {
        _bank = await BankDataService.GetBankByCodeAsync(BankCode);
        if (_bank != null)
        {
            _countryInfo = CountryService.GetCountryInfo(_bank.CountryCode ?? CountryCode);
            _viewCount = await ViewCountService.GetViewCountAsync(BankCode);
            _overallRating = (double)await RatingService.GetOverallRatingAsync(BankCode);
            var ratings = await RatingService.GetBankRatingsAsync(BankCode);
            _totalRatings = ratings.Count;

            // Extract metrics for tiles
            _groupedMetrics = MetricsExtractor.ExtractMetrics(_bank);
            BuildTransactionDestinations(_bank);
            BuildSceneLabels();
            BuildCardDesigns();
            _bankSerializedJson = JsonSerializer.Serialize(_bank, BankJsonSerializerOptions);

            // Set default language based on country if no preference exists
            await SetDefaultLanguageIfNeededAsync();
        }
        _loading = false;
    }

    private void BuildSceneLabels()
    {
        _sceneLabels = new List<string> { _bank?.BankName ?? "Overview" };
        if (_groupedMetrics != null)
        {
            foreach (var group in _groupedMetrics.Where(g => g.Key != BankMetricsExtractorService.OverviewRatingsSectionKey))
            {
                _sceneLabels.Add(GetLocalizedSectionTitle(group.Key));
            }
        }
        _sceneLabels.Add("Charts & Analytics");
    }

    private async Task SetDefaultLanguageIfNeededAsync()
    {
        try
        {
            var currentLang = Localization.GetCurrentLanguage();

            if (string.IsNullOrEmpty(currentLang) || currentLang == "en-US")
            {
                if (_bank?.CountryCode != null)
                {
                    var defaultLang = Localization.GetDefaultLanguageForCountry(_bank.CountryCode);

                    if (defaultLang != currentLang)
                    {
                        await Localization.SetLanguageAsync(defaultLang);
                    }
                }
            }
        }
        catch (InvalidOperationException)
        {
            // Ignore cookie setting errors if response has already started
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _bank != null)
        {
            await ViewCountService.IncrementViewCountAsync(BankCode);
            _viewCount = await ViewCountService.GetViewCountAsync(BankCode);

            // Initialize scene scroll tracking
            _sceneRef = DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("sceneScroll.initialize", _sceneRef);
            }
            catch (JSException)
            {
                // Scene scroll init may fail during prerender
            }

            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnActiveSceneChanged(int index)
    {
        if (_activeSceneIndex != index)
        {
            _activeSceneIndex = index;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private async Task ScrollToScene(int index)
    {
        try
        {
            await JS.InvokeVoidAsync("sceneScroll.scrollToScene", index);
        }
        catch (JSException)
        {
            // Ignore if JS not ready
        }
    }

    private bool HasNextScene(int sceneIndex)
    {
        return sceneIndex >= 0 && sceneIndex < _sceneLabels.Count - 1;
    }

    private Task ScrollToNextScene(int currentSceneIndex)
    {
        return HasNextScene(currentSceneIndex)
            ? ScrollToScene(currentSceneIndex + 1)
            : Task.CompletedTask;
    }

    private string GetTimeAgo(DateTime date)
    {
        var now = DateTime.UtcNow;
        var diff = now - date;

        if (diff.TotalDays < 1)
        {
            if (diff.TotalHours < 1)
                return "less than an hour ago";
            var hours = (int)diff.TotalHours;
            return hours == 1 ? "1 hour ago" : $"{hours} hours ago";
        }
        else if (diff.TotalDays < 7)
        {
            var days = (int)diff.TotalDays;
            return days == 1 ? "1 day ago" : $"{days} days ago";
        }
        else if (diff.TotalDays < 30)
        {
            var weeks = (int)(diff.TotalDays / 7);
            return weeks == 1 ? "1 week ago" : $"{weeks} weeks ago";
        }
        else if (diff.TotalDays < 365)
        {
            var months = (int)(diff.TotalDays / 30);
            return months == 1 ? "1 month ago" : $"{months} months ago";
        }
        else
        {
            var years = (int)(diff.TotalDays / 365);
            return years == 1 ? "1 year ago" : $"{years} years ago";
        }
    }

    private string GetSectionIcon(string sectionKey)
    {
        return sectionKey switch
        {
            BankMetricsExtractorService.OverviewRatingsSectionKey => "fas fa-star",
            BankMetricsExtractorService.SystemsCurrenciesSectionKey => "fas fa-cog",
            BankMetricsExtractorService.FeesCommissionsSectionKey => "fas fa-dollar-sign",
            BankMetricsExtractorService.ComplianceRiskSectionKey => "fas fa-shield-alt",
            BankMetricsExtractorService.DigitalSupportSectionKey => "fas fa-mobile-alt",
            BankMetricsExtractorService.ProductsServicesSectionKey => "fas fa-briefcase",
            _ => "fas fa-info-circle"
        };
    }

    private bool ShouldShowProgressBars(string sectionKey)
    {
        return sectionKey.Equals(BankMetricsExtractorService.OverviewRatingsSectionKey, StringComparison.Ordinal);
    }

    private string GetLocalizedSectionTitle(string sectionKey)
    {
        return Localization.GetString($"metric.section.{sectionKey}");
    }

    private void BuildTransactionDestinations(BankProfile bank)
    {
        _transactionDestinations = bank.Transactions?.OutgoingDestinations?
            .Select(destination => destination.Country?.Trim())
            .Where(country => !string.IsNullOrWhiteSpace(country))
            .Select(country => country!)
            .Where(country => !string.Equals(country, bank.HeadquartersCountry, StringComparison.OrdinalIgnoreCase))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList()
            ?? new List<string>();
    }

    private Task OpenTransactionRoadmap()
    {
        _isRoadmapModalVisible = true;
        return Task.CompletedTask;
    }

    private Task CloseTransactionRoadmapAsync()
    {
        _isRoadmapModalVisible = false;
        return Task.CompletedTask;
    }

    private Task ToggleBankJsonPopup()
    {
        _isBankJsonPopupVisible = !_isBankJsonPopupVisible;
        return Task.CompletedTask;
    }

    private Task CloseBankJsonPopup()
    {
        _isBankJsonPopupVisible = false;
        return Task.CompletedTask;
    }

    private void BuildCardDesigns()
    {
        // Use card designs from bank data, or provide placeholder data
        _cardDesigns = _bank?.CardDesigns?.Count > 0
            ? _bank.CardDesigns
            : new List<CardDesign>
            {
                new() { ImageUrl = "images/card-placeholder.png", Name = "Classic Card" },
                new() { ImageUrl = "images/card-placeholder.png", Name = "Premium Card" },
                new() { ImageUrl = "images/card-placeholder.png", Name = "Vertical Card", IsVertical = true },
            };
    }

    private Task OpenCardGallery()
    {
        _isCardGalleryVisible = true;
        return Task.CompletedTask;
    }

    private Task CloseCardGallery()
    {
        _isCardGalleryVisible = false;
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (_sceneRef != null)
        {
            try
            {
                await JS.InvokeVoidAsync("sceneScroll.dispose");
            }
            catch (JSDisconnectedException) { }
            _sceneRef.Dispose();
        }
    }
}
