@page "/banks"
@inject ILocalizationService Localization
@inject ICountryService CountryService
@rendermode InteractiveServer

<PageTitle>@Localization.GetString("page.banks.pageTitle")</PageTitle>

@* Neutral Nebula Background *@
<DynamicNebulaBackground />

<div style="position: relative; z-index: 1;">

@if (!string.IsNullOrWhiteSpace(Country) && _currentCountryInfo != null)
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/banks">Banks</a></li>
            <li class="breadcrumb-item active" aria-current="page">@_currentCountryInfo.Flag @_currentCountryInfo.Name</li>
        </ol>
    </nav>
}

<h1><i class="fas fa-building" aria-hidden="true"></i> @Localization.GetString("page.banks.title")</h1>

@if (!string.IsNullOrWhiteSpace(Country) && _currentCountryInfo != null)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-3" role="status">
        <div>
            <i class="fas fa-filter" aria-hidden="true"></i> 
            <strong>Showing banks in @_currentCountryInfo.Flag @_currentCountryInfo.Name</strong>
            <span class="ms-2 badge bg-primary">@GetFilteredBanks().Count() @(GetFilteredBanks().Count() == 1 ? "bank" : "banks")</span>
        </div>
        <a href="/banks" class="btn btn-sm btn-outline-secondary" aria-label="Clear country filter">
            <i class="fas fa-times" aria-hidden="true"></i> Clear filter
        </a>
    </div>
}

<section class="row mb-4" aria-label="Bank filters and search">
    <div class="col-md-3">
        <div class="input-group">
            <label for="bank-search" class="visually-hidden">Search banks</label>
            <span class="input-group-text"><i class="fas fa-search" aria-hidden="true"></i></span>
            <input id="bank-search" type="text" class="form-control" placeholder="@Localization.GetString("page.banks.searchPlaceholder")" @bind="_searchTerm" @bind:event="oninput" aria-label="Search banks by name" />
        </div>
    </div>
    <div class="col-md-2">
        <label for="country-filter" class="visually-hidden">Filter by country</label>
        <select id="country-filter" class="form-select" @bind="_selectedCountry" @bind:after="OnCountryFilterChanged" aria-label="Filter banks by country">
            <option value="">All Countries</option>
            @foreach (var country in CountryService.GetAllCountries().OrderBy(c => c.Name))
            {
                <option value="@country.Code">@country.Flag @country.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label for="currency-filter" class="visually-hidden">Filter by currency</label>
        <select id="currency-filter" class="form-select" @bind="_filterCurrency" aria-label="Filter banks by currency">
            <option value="">@Localization.GetString("page.banks.allCurrencies")</option>
            <option value="USD">USD</option>
            <option value="EUR">EUR</option>
            <option value="GBP">GBP</option>
            <option value="BTC">@Localization.GetString("page.banks.crypto")</option>
        </select>
    </div>
    <div class="col-md-3">
        <label for="premium-filter" class="visually-hidden">Filter by premium banking</label>
        <select id="premium-filter" class="form-select" @bind="_filterPremium" aria-label="Filter by premium banking availability">
            <option value="">@Localization.GetString("page.banks.premiumBanking")</option>
            <option value="yes">@Localization.GetString("page.banks.available")</option>
            <option value="no">@Localization.GetString("page.banks.notAvailable")</option>
        </select>
    </div>
    <div class="col-md-2">
        <label for="sort-select" class="visually-hidden">Sort banks</label>
        <select id="sort-select" class="form-select" @bind="_sortBy" aria-label="Sort banks by criteria">
            <option value="name">@Localization.GetString("page.banks.sortByName")</option>
            <option value="rating">@Localization.GetString("page.banks.sortByRating")</option>
            <option value="views">@Localization.GetString("page.banks.sortByViews")</option>
        </select>
    </div>
</section>

@if (_loading)
{
    <div class="skeleton-grid" role="status" aria-label="Loading banks">
        <span class="visually-hidden">Loading banks...</span>
        @for (int i = 0; i < 6; i++)
        {
            <BankCardSkeleton />
        }
    </div>
}
else
{
    var groupedBanks = GetGroupedBanks();
    
    @if (!groupedBanks.Any())
    {
        <div class="alert alert-info mt-4" role="alert">@Localization.GetString("page.banks.noMatch")</div>
    }
    else
    {
        @foreach (var countryGroup in groupedBanks)
        {
            <section class="country-section mb-5" aria-labelledby="country-@countryGroup.CountryCode">
                <h2 id="country-@countryGroup.CountryCode" class="mb-3">
                    <span class="me-2" aria-hidden="true">@countryGroup.Flag</span>
                    @countryGroup.CountryName
                    <span class="badge bg-secondary ms-2">@countryGroup.Banks.Count</span>
                </h2>
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    @foreach (var bank in countryGroup.Banks)
                    {
                        <div class="col fade-in">
                            <BankCard Bank="bank" OverallRating="0" ViewCount="0" />
                        </div>
                    }
                </div>
            </section>
        }
    }
}

</div>

@code {
    private List<BankProfile> _banks = new();
    private string _searchTerm = "";
    private string _selectedCountry = "";
    private string _filterCurrency = "";
    private string _filterPremium = "";
    private string _sortBy = "name";
    private bool _loading = true;
    private CountryInfo? _currentCountryInfo;

    [Inject] private IBankDataService BankService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    [SupplyParameterFromQuery]
    public string? Country { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _banks = await BankService.GetAllBanksAsync();
        
        // Set filter from query parameter
        if (!string.IsNullOrWhiteSpace(Country))
        {
            _selectedCountry = Country.ToLowerInvariant();
            _currentCountryInfo = CountryService.GetCountryInfo(_selectedCountry);
        }
        
        _loading = false;
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(Country))
        {
            _selectedCountry = Country.ToLowerInvariant();
            _currentCountryInfo = CountryService.GetCountryInfo(_selectedCountry);
        }
        else
        {
            _selectedCountry = "";
            _currentCountryInfo = null;
        }
    }

    private void OnCountryFilterChanged()
    {
        // Update URL when dropdown filter changes
        if (!string.IsNullOrWhiteSpace(_selectedCountry))
        {
            Navigation.NavigateTo($"/banks?country={_selectedCountry}");
        }
        else
        {
            Navigation.NavigateTo("/banks");
        }
    }

    private IEnumerable<BankProfile> GetFilteredBanks()
    {
        var filtered = _banks.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            filtered = filtered.Where(b => 
                b.BankName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (b.Description?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        if (!string.IsNullOrWhiteSpace(_selectedCountry))
        {
            filtered = filtered.Where(b => 
                b.CountryCode?.Equals(_selectedCountry, StringComparison.OrdinalIgnoreCase) ?? false);
        }

        if (!string.IsNullOrWhiteSpace(_filterCurrency))
        {
            filtered = filtered.Where(b => 
                b.TechnicalInfo?.AvailableCurrencies?.Contains(_filterCurrency) ?? false);
        }

        if (_filterPremium == "yes")
        {
            filtered = filtered.Where(b => b.TechnicalInfo?.PremiumBanking?.Available == true);
        }
        else if (_filterPremium == "no")
        {
            filtered = filtered.Where(b => b.TechnicalInfo?.PremiumBanking?.Available == false);
        }

        filtered = _sortBy switch
        {
            "name" => filtered.OrderBy(b => b.BankName),
            "rating" => filtered.OrderByDescending(b => b.BankName),
            "views" => filtered.OrderByDescending(b => b.BankName),
            _ => filtered
        };

        return filtered;
    }

    private List<CountryBankGroup> GetGroupedBanks()
    {
        var filtered = GetFilteredBanks();
        
        return filtered
            .Where(b => !string.IsNullOrWhiteSpace(b.CountryCode))
            .GroupBy(b => b.CountryCode!.ToLowerInvariant())
            .Select(g => new CountryBankGroup
            {
                CountryCode = g.Key,
                CountryName = GetCountryName(g.Key),
                Flag = GetCountryFlag(g.Key),
                Banks = g.ToList()
            })
            .OrderBy(g => g.CountryName)
            .ToList();
    }

    private string GetCountryName(string countryCode)
    {
        var countryInfo = CountryService.GetCountryInfo(countryCode);
        return countryInfo?.Name ?? countryCode.ToUpperInvariant();
    }

    private string GetCountryFlag(string countryCode)
    {
        var countryInfo = CountryService.GetCountryInfo(countryCode);
        return countryInfo?.Flag ?? "🏴";
    }

    private class CountryBankGroup
    {
        public required string CountryCode { get; set; }
        public required string CountryName { get; set; }
        public required string Flag { get; set; }
        public required List<BankProfile> Banks { get; set; }
    }
}
