@page "/"
@inject ILocalizationService Localization
@rendermode InteractiveServer

<PageTitle>@Localization.GetString("page.home.pageTitle")</PageTitle>

@* Aurora Mesh Background - Showcase Style *@
<AuroraBackground />

<div class="home-page-showcase" style="position: relative; z-index: 1;">
    @* Hero Section - Showcase Inspired *@
    <section class="hero-showcase" aria-labelledby="hero-title">
        <div class="hero-content">
            <div class="hero-tag-wrapper">
                <span class="hero-tag">Bank Profiles Directory</span>
            </div>
            <h1 id="hero-title" class="hero-title">
                <i class="fas fa-university hero-icon" aria-hidden="true"></i>
                @Localization.GetString("page.home.title")
            </h1>
            <p class="hero-subtitle">
                @Localization.GetString("page.home.subtitle")
            </p>
            <div class="hero-actions">
                <a class="hero-btn" href="/banks" role="button" aria-label="Browse all banks">
                    <i class="fas fa-search" aria-hidden="true"></i> 
                    @Localization.GetString("page.home.browseBanks")
                </a>
            </div>
        </div>
    </section>

    <div class="divider-showcase"></div>

    <section class="country-selector mb-5" aria-labelledby="country-selector-heading">
        <h2 id="country-selector-heading" class="mb-4"><i class="fas fa-globe" aria-hidden="true"></i> Browse by Country</h2>
        @if (_loading)
        {
            <div class="text-center p-3">
                <div class="spinner-border spinner-border-sm text-primary" role="status">
                    <span class="visually-hidden">Loading countries...</span>
                </div>
            </div>
        }
        else
        {
            <nav aria-label="Browse banks by country">
                <div class="row row-cols-2 row-cols-md-5 g-3 fade-in-fast">
                    @foreach (var country in _countriesWithBanks)
                    {
                        <div class="col">
                            <a href="/banks?country=@country.Code" class="country-card text-decoration-none d-block" aria-label="View @country.BankCount @(country.BankCount == 1 ? "bank" : "banks") in @country.Name">
                                <div class="card h-100 text-center hover-shadow">
                                    <div class="card-body py-3">
                                        <div class="fs-1 mb-2" aria-hidden="true">@country.Flag</div>
                                        <h3 class="card-title mb-1 h6">@country.Name</h3>
                                        <span class="badge bg-primary">@country.BankCount @(country.BankCount == 1 ? "bank" : "banks")</span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </nav>
        }
    </section>

    <section aria-labelledby="featured-banks-heading">
        <h2 id="featured-banks-heading" class="mb-4">@Localization.GetString("page.home.featuredBanks")</h2>
        
        @if (_loading)
        {
            <div class="skeleton-grid" aria-label="Loading featured banks" role="status">
                @for (int i = 0; i < 6; i++)
                {
                    <BankCardSkeleton />
                }
            </div>
        }
        else if (_error != null)
        {
            <div class="alert alert-danger" role="alert">
                <i class="fas fa-exclamation-triangle" aria-hidden="true"></i> @Localization.GetString("page.home.errorLoading") @_error
            </div>
        }
        else if (!_banks.Any())
        {
            <div class="alert alert-info" role="alert">
                <i class="fas fa-info-circle" aria-hidden="true"></i> @Localization.GetString("page.home.noBanks")
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-3 g-4 fade-in">
                @foreach (var bank in _banks.Take(6))
                {
                    <div class="col">
                        <GlassBankCard Bank="bank" OverallRating="0" ViewCount="0" />
                    </div>
                }
            </div>

            <div class="text-center mt-4">
                <a href="/banks" class="btn btn-outline-primary" aria-label="View all banks">
                    @Localization.GetString("page.home.viewAllBanks") <i class="fas fa-arrow-right" aria-hidden="true"></i>
                </a>
            </div>
        }
    </section>
</div>

<style>
    /* ═══════════════════════════════════════════════════════════
       HOME PAGE - SHOWCASE STYLE
       Inspired by pure-css-effects-showcase
       ═══════════════════════════════════════════════════════════ */
    
    .home-page-showcase {
        min-height: 100vh;
        color: var(--text-primary);
    }
    
    /* ── HERO SECTION ────────────────────────────────────────── */
    .hero-showcase {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 6rem 2rem;
        text-align: center;
        animation: fadeInUp 1s ease-out;
    }
    
    .hero-content {
        max-width: 900px;
        width: 100%;
    }
    
    .hero-tag-wrapper {
        margin-bottom: 2rem;
        animation: fadeInUp 0.8s ease-out both;
    }
    
    .hero-tag {
        font-family: var(--font-mono, 'DM Mono', monospace);
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-muted, rgba(232, 230, 240, 0.5));
        border: 1px solid var(--border-color, rgba(255, 255, 255, 0.1));
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        display: inline-block;
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.03);
    }
    
    .hero-title {
        font-family: var(--font-display, -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif);
        font-size: clamp(2.5rem, 8vw, 6rem);
        font-weight: 900;
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin: 1rem 0;
        background: linear-gradient(
            135deg,
            var(--accent-1, #b3ffc8) 0%,
            var(--accent-3, #5eadff) 50%,
            var(--accent-2, #ff6ef7) 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: fadeInUp 0.8s ease-out 0.1s both;
    }
    
    .hero-icon {
        display: inline-block;
        margin-right: 0.5rem;
        animation: float 3s ease-in-out infinite;
    }
    
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    
    .hero-subtitle {
        font-family: var(--font-mono, 'DM Mono', monospace);
        font-size: clamp(1rem, 2.5vw, 1.4rem);
        color: var(--text-secondary, rgba(232, 230, 240, 0.7));
        letter-spacing: 0.02em;
        margin: 2rem 0;
        line-height: 1.6;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }
    
    .hero-actions {
        margin-top: 3rem;
        animation: fadeInUp 0.8s ease-out 0.3s both;
    }
    
    .hero-btn {
        display: inline-block;
        padding: 1rem 2.5rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 50px;
        text-decoration: none;
        backdrop-filter: blur(20px);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }
    
    .hero-btn::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            105deg,
            transparent 40%,
            rgba(255, 255, 255, 0.15) 50%,
            transparent 60%
        );
        background-size: 200% 100%;
        background-position: -100% 0;
        transition: background-position 0.6s ease;
    }
    
    .hero-btn:hover {
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.4);
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }
    
    .hero-btn:hover::before {
        background-position: 200% 0;
    }
    
    .hero-btn:active {
        transform: translateY(-1px);
    }
    
    /* ── DIVIDER ─────────────────────────────────────────────── */
    .divider-showcase {
        width: 100%;
        height: 1px;
        background: linear-gradient(
            90deg,
            transparent,
            var(--border-color, rgba(255, 255, 255, 0.1)) 30%,
            var(--border-color, rgba(255, 255, 255, 0.1)) 70%,
            transparent
        );
        margin: 4rem 0;
    }
    
    /* ── SECTIONS ────────────────────────────────────────────── */
    .country-selector,
    section[aria-labelledby="featured-banks-heading"] {
        padding: 4rem 2rem;
        max-width: 1400px;
        margin: 0 auto;
        animation: fadeInUp 0.8s ease-out 0.4s both;
    }
    
    .country-selector h2,
    section[aria-labelledby="featured-banks-heading"] h2 {
        font-family: var(--font-display, -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif);
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 2rem;
        color: var(--text-primary);
    }
    
    /* ── ANIMATIONS ──────────────────────────────────────────── */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* ── RESPONSIVE ──────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .hero-showcase {
            padding: 4rem 1.5rem;
            min-height: 80vh;
        }
        
        .hero-title {
            font-size: clamp(2rem, 10vw, 3rem);
        }
        
        .hero-subtitle {
            font-size: 1rem;
        }
        
        .hero-btn {
            padding: 0.875rem 2rem;
            font-size: 1rem;
        }
    }
    
    /* ── THEME SUPPORT ───────────────────────────────────────── */
    [data-theme="light"] .hero-tag {
        color: rgba(26, 26, 26, 0.6);
        border-color: rgba(0, 0, 0, 0.1);
        background: rgba(0, 0, 0, 0.03);
    }
    
    [data-theme="light"] .hero-btn {
        background: rgba(0, 0, 0, 0.05);
        border-color: rgba(0, 0, 0, 0.15);
        color: #1a1a1a;
    }
    
    [data-theme="light"] .hero-btn:hover {
        background: rgba(0, 0, 0, 0.1);
        border-color: rgba(0, 0, 0, 0.25);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }
</style>

@code {
    private List<BankProfile> _banks = new();
    private List<CountryWithBankCount> _countriesWithBanks = new();
    private bool _loading = true;
    private string? _error;

    [Inject] private IBankDataService BankService { get; set; } = default!;
    [Inject] private ICountryService CountryService { get; set; } = default!;
    [Inject] private ILogger<Home> Logger { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _banks = await BankService.GetAllBanksAsync();
            
            // Calculate bank counts per country
            var banksByCountry = _banks
                .Where(b => !string.IsNullOrWhiteSpace(b.CountryCode))
                .GroupBy(b => b.CountryCode!.ToLowerInvariant())
                .ToDictionary(g => g.Key, g => g.Count());

            _countriesWithBanks = CountryService.GetAllCountries()
                .Where(c => banksByCountry.ContainsKey(c.Code))
                .Select(c => new CountryWithBankCount
                {
                    Code = c.Code,
                    Name = c.Name,
                    Flag = c.Flag,
                    BankCount = banksByCountry[c.Code]
                })
                .OrderByDescending(c => c.BankCount)
                .ThenBy(c => c.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading banks");
            _error = "Unable to load bank information. Please try again later.";
        }
        finally
        {
            _loading = false;
        }
    }

    private class CountryWithBankCount
    {
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string Flag { get; set; } = "";
        public int BankCount { get; set; }
    }
}
