@using System.Globalization
@using BankProfiles.Web.Domain.Common.Metrics
@inject IJSRuntime JSRuntime

<div class="@GetCssClasses()" data-tilt role="region" aria-label="@Metric.Label metric" @onclick="HandleClick">
    <div class="glass-card-content metric-tile-inner">
        <div class="metric-header">
            <div class="metric-label">
                @Metric.Label
            </div>
            @if (!string.IsNullOrEmpty(Metric.Icon))
            {
                <div class="metric-icon" aria-hidden="true">
                    <i class="@Metric.Icon"></i>
                </div>
            }
        </div>

        @if (IsTotalClientsMetric)
        {
            <div class="total-clients-illustration" aria-hidden="true">
                <svg class="total-clients-svg" viewBox="0 0 360 220" xmlns="http://www.w3.org/2000/svg" focusable="false">
                    <defs>
                        <linearGradient id="clientsGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="rgba(94, 173, 255, 0.88)" />
                            <stop offset="55%" stop-color="rgba(0, 122, 255, 0.74)" />
                            <stop offset="100%" stop-color="rgba(52, 199, 89, 0.72)" />
                        </linearGradient>
                        <radialGradient id="clientsGlow" cx="50%" cy="45%" r="55%">
                            <stop offset="0%" stop-color="rgba(255,255,255,0.72)" />
                            <stop offset="100%" stop-color="rgba(255,255,255,0)" />
                        </radialGradient>
                        <linearGradient id="clientsBars" x1="0%" y1="0%" x2="100%" y2="0%">
                            <stop offset="0%" stop-color="rgba(255,255,255,0.26)" />
                            <stop offset="100%" stop-color="rgba(255,255,255,0.06)" />
                        </linearGradient>
                    </defs>
                    <circle class="pulse-ring" cx="252" cy="86" r="62" fill="none" stroke="url(#clientsGradient)" stroke-width="10" opacity="0.9" />
                    <circle cx="252" cy="86" r="46" fill="url(#clientsGlow)" opacity="0.82" />
                    <path d="M194 86h116M252 28a106 106 0 0 0 0 116M252 28a106 106 0 0 1 0 116" stroke="url(#clientsGradient)" stroke-width="6" fill="none" stroke-linecap="round" opacity="0.84" />

                    <rect x="28" y="122" width="160" height="76" rx="16" fill="url(#clientsBars)" stroke="rgba(255,255,255,0.36)" stroke-width="2" />
                    <rect x="44" y="106" width="172" height="82" rx="16" fill="rgba(255,255,255,0.24)" stroke="rgba(255,255,255,0.48)" stroke-width="2" />
                    <rect x="60" y="92" width="182" height="88" rx="18" fill="rgba(255,255,255,0.78)" stroke="rgba(0,122,255,0.3)" stroke-width="2" />

                    <rect x="80" y="116" width="118" height="10" rx="5" fill="rgba(0,122,255,0.36)" />
                    <rect x="80" y="134" width="92" height="8" rx="4" fill="rgba(0,122,255,0.2)" />
                    <circle cx="210" cy="150" r="11" fill="rgba(52,199,89,0.72)" />
                    <circle class="float-dot-a" cx="278" cy="44" r="8" fill="rgba(255,255,255,0.74)" />
                    <circle class="float-dot-b" cx="314" cy="106" r="6" fill="rgba(94,173,255,0.72)" />
                </svg>
            </div>
        }
        
        <div class="metric-value">
            @if (Metric.Type == MetricType.List && Metric.Value is List<string> list)
            {
                <div class="metric-chips">
                    @foreach (var item in list.Take(3))
                    {
                        <span class="chip">@item</span>
                    }
                    @if (list.Count > 3)
                    {
                        <span class="chip more">+@(list.Count - 3)</span>
                    }
                </div>
            }
            else if (Metric.Type == MetricType.Percentage)
            {
                <div class="percentage-container">
                    <span class="percentage-value" @ref="_metricValueElement" data-counter-enabled="@CounterEnabledAttribute">@GetDisplayValueForRender()</span>
                    @if (ShowProgressBar)
                    {
                        <div class="progress-bar-wrapper">
                            <div class="progress-bar" style="width: @GetProgressWidth()%"></div>
                        </div>
                    }
                </div>
            }
            else
            {
                <span class="metric-value-number @(IsTotalClientsMetric ? "total-clients-value-number" : string.Empty)"
                      @ref="_metricValueElement"
                      data-counter-enabled="@CounterEnabledAttribute">@GetDisplayValueForRender()</span>
            }
        </div>
        
        @if (!string.IsNullOrEmpty(Metric.Unit) && Metric.Type != MetricType.Percentage)
        {
            <div class="metric-unit">@Metric.Unit</div>
        }
    </div>
</div>

<style>
    /* Glass Metric Tile Specific Styles */
    .glass-card.metric-tile {
        min-height: 160px;
        padding: 1.5rem;
    }
    
    .glass-card.metric-tile-compact {
        min-height: 140px;
        padding: 1.25rem;
    }
    
    .metric-tile-inner {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        height: 100%;
        justify-content: space-between;
        position: relative;
        z-index: 2;
    }
    
    /* Metric Header */
    .metric-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.5rem;
    }
    
    .metric-label {
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        opacity: 0.7;
        line-height: 1.4;
        flex: 1;
    }
    
    .metric-icon {
        font-size: 1.25rem;
        opacity: 0.6;
        flex-shrink: 0;
        transition: opacity 0.2s ease, transform 0.2s ease;
    }
    
    .glass-card:hover .metric-icon {
        opacity: 0.9;
        transform: scale(1.1);
    }
    
    /* Metric Value */
    .metric-value {
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.1;
        margin-top: 0.25rem;
    }
    
    .metric-unit {
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: 0.875rem;
        font-weight: 400;
        opacity: 0.6;
        margin-top: 0.25rem;
    }
    
    /* Metric Chips (for list types) */
    .metric-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }
    
    .chip {
        display: inline-block;
        padding: 0.35rem 0.75rem;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 500;
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
        backdrop-filter: blur(10px);
    }
    
    .chip.more {
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.25);
        color: var(--text-primary);
    }
    
    /* Percentage Progress Bar */
    .percentage-container {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    
    .progress-bar-wrapper {
        width: 100%;
        height: 6px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }
    
    .progress-bar {
        height: 100%;
        background: var(--bank-accent, #007AFF);
        border-radius: 3px;
        transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    /* Alert Levels */
    .glass-card.alert-alert .metric-value {
        color: #FF3B30;
    }
    
    .glass-card.alert-warning .metric-value {
        color: #FF9500;
    }
    
    .glass-card.alert-success .metric-value {
        color: #34C759;
    }

    .glass-card.metric-tile.metric-tile-featured.total-clients-featured {
        min-height: 300px;
        width: 100%;
        border-radius: 12px;
        background:
            linear-gradient(150deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.07) 55%, rgba(94, 173, 255, 0.12) 100%),
            radial-gradient(120% 100% at 88% 100%, rgba(94, 173, 255, 0.2) 0%, rgba(0, 0, 0, 0) 72%);
        border-color: rgba(255, 255, 255, 0.28);
    }

    .scene-hero .glass-card.metric-tile.metric-tile-featured.total-clients-featured {
        height: clamp(300px, 50vh, 560px);
    }

    .glass-card.metric-tile.metric-tile-featured.total-clients-featured .metric-tile-inner {
        min-height: 100%;
    }

    .glass-card.metric-tile.metric-tile-featured.total-clients-featured .metric-header {
        position: relative;
        z-index: 3;
    }

    .glass-card.metric-tile.metric-tile-featured.total-clients-featured .metric-value {
        margin-top: auto;
        width: 100%;
        position: relative;
        z-index: 3;
    }

    .total-clients-value-number {
        display: block;
        width: 100%;
        font-size: clamp(2.8rem, 6vw, 5rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 0.94;
    }

    .total-clients-illustration {
        position: absolute;
        right: -26px;
        bottom: -30px;
        width: min(60%, 360px);
        opacity: 0.88;
        pointer-events: none;
        z-index: 1;
        filter: drop-shadow(0 16px 30px rgba(0, 0, 0, 0.15));
    }

    .total-clients-svg {
        width: 100%;
        height: auto;
        display: block;
    }

    .total-clients-svg .pulse-ring {
        animation: totalClientsPulse 4.4s ease-in-out infinite;
        transform-origin: 252px 86px;
    }

    .total-clients-svg .float-dot-a {
        animation: totalClientsFloatA 3.4s ease-in-out infinite;
    }

    .total-clients-svg .float-dot-b {
        animation: totalClientsFloatB 4s ease-in-out infinite;
    }

    @@keyframes totalClientsPulse {
        0%, 100% {
            transform: scale(1);
            opacity: 0.9;
        }
        50% {
            transform: scale(1.05);
            opacity: 0.65;
        }
    }

    @@keyframes totalClientsFloatA {
        0%, 100% {
            transform: translateY(0);
            opacity: 0.78;
        }
        50% {
            transform: translateY(-8px);
            opacity: 0.95;
        }
    }

    @@keyframes totalClientsFloatB {
        0%, 100% {
            transform: translate(0, 0);
            opacity: 0.72;
        }
        50% {
            transform: translate(-6px, -9px);
            opacity: 0.92;
        }
    }

    /* Boolean Tiles */
    .glass-card.boolean-true {
        background: linear-gradient(135deg, rgba(52, 199, 89, 0.2) 0%, rgba(48, 209, 88, 0.15) 100%);
        border-color: rgba(255, 255, 255, 0.2);
    }
    
    .glass-card.boolean-false {
        opacity: 0.6;
    }
    
    /* Theme Support */
    [data-theme="dark"] .chip {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
    }
    
    [data-theme="light"] .chip {
        background: rgba(0, 0, 0, 0.05);
        border-color: rgba(0, 0, 0, 0.1);
        color: var(--text-primary);
    }
    
    /* Responsive */
    @@media (max-width: 768px) {
        .glass-card.metric-tile {
            min-height: 120px;
            padding: 1rem;
        }
        
        .metric-value {
            font-size: 1.5rem;
        }
        
        .metric-label {
            font-size: 0.65rem;
        }

        .glass-card.metric-tile.metric-tile-featured.total-clients-featured {
            min-height: 220px;
            height: clamp(220px, 42vh, 360px);
        }

        .total-clients-illustration {
            width: min(58%, 230px);
            opacity: 0.78;
            right: -16px;
            bottom: -16px;
        }

        .total-clients-value-number {
            font-size: clamp(2.1rem, 9vw, 3.3rem);
        }
    }
</style>

@code {
    private const int CounterAnimationDurationMs = 900;
    private const string TotalClientsMetricKey = "totalClients";

    [Parameter]
    public required MetricDto Metric { get; set; }
    
    [Parameter]
    public bool ShowProgressBar { get; set; } = false;
    
    [Parameter]
    public EventCallback<MetricDto> OnClick { get; set; }

    private ElementReference _metricValueElement;
    private IReadOnlyDictionary<string, object>? _counterAnimationOptions;
    private string _lastAnimatedMetricKey = string.Empty;

    private string CounterEnabledAttribute => _counterAnimationOptions is null ? "false" : "true";

    protected override void OnParametersSet()
    {
        _counterAnimationOptions = BuildCounterAnimationOptions();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_counterAnimationOptions is null)
        {
            return;
        }

        var currentMetricKey = BuildMetricKey();
        if (!firstRender && currentMetricKey == _lastAnimatedMetricKey)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("counterHelper.animateValue", _metricValueElement, _counterAnimationOptions);
            _lastAnimatedMetricKey = currentMetricKey;
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected while animating; no further action needed.
        }
        catch (InvalidOperationException ex) when (ex.Message.Contains("circuit has disconnected", StringComparison.OrdinalIgnoreCase))
        {
            // Alternative circuit-disconnect path in Blazor Server.
        }
    }
    
    private string GetCssClasses()
    {
        var classes = new List<string> { "glass-card", "metric-tile", Metric.GetCssClass() };

        if (IsTotalClientsMetric)
        {
            classes.Add("metric-tile-featured");
            classes.Add("total-clients-featured");
        }
        
        var alertLevel = Metric.GetAlertLevel();
        if (alertLevel != "normal")
        {
            classes.Add($"alert-{alertLevel}");
        }
        
        return string.Join(" ", classes);
    }
    
    private double GetProgressWidth()
    {
        return TryConvertToDouble(Metric.Value, out var value) ? Math.Min(value, 100) : 0;
    }

    private string GetDisplayValueForRender()
    {
        if (_counterAnimationOptions is null)
        {
            if (IsTotalClientsMetric && TryConvertToDouble(Metric.Value, out var totalClientsValue))
            {
                return totalClientsValue.ToString("N0", CultureInfo.CurrentCulture);
            }

            return Metric.FormattedValue;
        }

        var decimals = (int)_counterAnimationOptions["decimals"];
        var prefix = (string)_counterAnimationOptions["prefix"];
        var suffix = (string)_counterAnimationOptions["suffix"];
        var useGrouping = (bool)_counterAnimationOptions["useGrouping"];
        var zeroValue = useGrouping
            ? 0d.ToString($"N{decimals}", CultureInfo.CurrentCulture)
            : 0d.ToString($"F{decimals}", CultureInfo.CurrentCulture);

        return $"{prefix}{zeroValue}{suffix}";
    }

    private IReadOnlyDictionary<string, object>? BuildCounterAnimationOptions()
    {
        if (!TryGetMetricNumericValue(out var endValue))
        {
            return null;
        }

        var decimals = GetDecimalPlacesForMetric();
        var prefix = Metric.Type == MetricType.Currency ? Metric.Unit ?? "$" : string.Empty;
        var suffix = Metric.Type == MetricType.Percentage ? "%" : string.Empty;

        return new Dictionary<string, object>
        {
            ["start"] = 0d,
            ["end"] = endValue,
            ["duration"] = CounterAnimationDurationMs,
            ["decimals"] = decimals,
            ["prefix"] = prefix,
            ["suffix"] = suffix,
            ["useGrouping"] = IsTotalClientsMetric
        };
    }

    private bool TryGetMetricNumericValue(out double numericValue)
    {
        numericValue = 0;

        if (Metric.Type is not (MetricType.Numeric or MetricType.Percentage or MetricType.Currency))
        {
            return false;
        }

        return TryConvertToDouble(Metric.Value, out numericValue);
    }

    private static bool TryConvertToDouble(object? value, out double result)
    {
        switch (value)
        {
            case byte byteValue:
                result = byteValue;
                return true;
            case sbyte sbyteValue:
                result = sbyteValue;
                return true;
            case short shortValue:
                result = shortValue;
                return true;
            case ushort ushortValue:
                result = ushortValue;
                return true;
            case int intValue:
                result = intValue;
                return true;
            case uint uintValue:
                result = uintValue;
                return true;
            case long longValue:
                result = longValue;
                return true;
            case ulong ulongValue:
                result = ulongValue;
                return true;
            case float floatValue:
                result = floatValue;
                return true;
            case double doubleValue:
                result = doubleValue;
                return true;
            case decimal decimalValue:
                result = (double)decimalValue;
                return true;
            case string textValue when double.TryParse(textValue, NumberStyles.Float, CultureInfo.InvariantCulture, out var invariantValue):
                result = invariantValue;
                return true;
            case string textValue when double.TryParse(textValue, NumberStyles.Float, CultureInfo.CurrentCulture, out var cultureValue):
                result = cultureValue;
                return true;
            default:
                result = 0;
                return false;
        }
    }

    private int GetDecimalPlacesForMetric()
    {
        return Metric.Type switch
        {
            MetricType.Percentage => 1,
            MetricType.Currency => 2,
            MetricType.Numeric => GetDecimalPlacesFromValue(Metric.Value),
            _ => 0
        };
    }

    private static int GetDecimalPlacesFromValue(object value)
    {
        return value switch
        {
            decimal decimalValue => Math.Min((decimal.GetBits(decimalValue)[3] >> 16) & 0x7F, 2),
            double doubleValue => GetDoubleDecimalPlaces(doubleValue),
            float floatValue => GetDoubleDecimalPlaces(floatValue),
            string textValue when decimal.TryParse(textValue, NumberStyles.Float, CultureInfo.InvariantCulture, out var parsedDecimal)
                => Math.Min((decimal.GetBits(parsedDecimal)[3] >> 16) & 0x7F, 2),
            _ => 0
        };
    }

    private static int GetDoubleDecimalPlaces(double value)
    {
        var text = value.ToString("0.################", CultureInfo.InvariantCulture);
        var decimalSeparatorIndex = text.IndexOf('.');
        if (decimalSeparatorIndex < 0)
        {
            return 0;
        }

        return Math.Min(text.Length - decimalSeparatorIndex - 1, 2);
    }

    private string BuildMetricKey()
    {
        var rawValue = Convert.ToString(Metric.Value, CultureInfo.InvariantCulture) ?? string.Empty;
        return $"{Metric.Key}|{Metric.Type}|{rawValue}|{Metric.Unit}";
    }

    private bool IsTotalClientsMetric => Metric.Key.Equals(TotalClientsMetricKey, StringComparison.Ordinal);

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync(Metric);
    }
}
