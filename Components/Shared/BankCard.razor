@inject ICountryService CountryService

<div class="bank-card card h-100 shadow-sm">
    <div class="card-body">
        <h5 class="card-title">
            @if (Bank?.CountryCode != null)
            {
                var countryInfo = CountryService.GetCountryInfo(Bank.CountryCode);
                if (countryInfo != null)
                {
                    <span class="me-2">@countryInfo.Flag</span>
                }
            }
            @Bank?.BankName
        </h5>
        <p class="card-text text-muted small">
            @{
                var desc = Bank?.Description ?? "";
                var displayDesc = desc.Length > 100 ? desc.Substring(0, 100) + "..." : desc;
            }
            @displayDesc
        </p>

        @if (OverallRating > 0)
        {
            <div class="rating mb-2">
                <span class="badge bg-success">
                    <i class="fas fa-star"></i> @OverallRating.ToString("F1")
                </span>
            </div>
        }

        @if (ViewCount > 0)
        {
            <div class="view-count text-muted small">
                <i class="fas fa-eye"></i> @ViewCount.ToString("N0") views
            </div>
        }
    </div>
    <div class="card-footer bg-transparent">
        <a href="/@Bank?.CountryCode/@Bank?.BankCode" class="btn btn-sm btn-outline-primary w-100">
            View Details <i class="fas fa-arrow-right ms-1"></i>
        </a>
    </div>
</div>

@code {
    [Parameter] public BankProfile? Bank { get; set; }
    [Parameter] public decimal OverallRating { get; set; }
    [Parameter] public long ViewCount { get; set; }
}
