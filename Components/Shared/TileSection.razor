@inject ModalService ModalService

<section class="@GetSectionCssClass()" aria-labelledby="section-@SectionId">
    <h2 id="section-@SectionId" class="tile-section-header">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <i class="@Icon section-icon" aria-hidden="true"></i>
        }
        @Title
    </h2>
    
    <div class="@GetGridCssClass()" role="list">
        @foreach (var metric in Metrics)
        {
            <div role="listitem" class="@GetMetricItemCssClass(metric)">
                <GlassMetricTile Metric="metric" ShowProgressBar="@ShowProgressBars" OnClick="HandleTileClick" />
            </div>
        }
    </div>
</section>

@code {
    private const string TotalClientsMetricKey = "totalClients";

    [Parameter]
    public required string Title { get; set; }

    [Parameter]
    public required string SectionKey { get; set; }
    
    [Parameter]
    public required List<MetricDto> Metrics { get; set; }
    
    [Parameter]
    public string? Icon { get; set; }
    
    [Parameter]
    public bool ShowProgressBars { get; set; } = false;
    
    private string SectionId => SectionKey;
    private bool IsOverviewRatingsSection => SectionKey.Equals(BankMetricsExtractorService.OverviewRatingsSectionKey, StringComparison.Ordinal);

    private string GetSectionCssClass()
    {
        return IsOverviewRatingsSection ? "tile-section overview-ratings-section" : "tile-section";
    }

    private string GetGridCssClass()
    {
        return IsOverviewRatingsSection ? "tile-grid overview-ratings-grid" : "tile-grid";
    }

    private string GetMetricItemCssClass(MetricDto metric)
    {
        var classes = new List<string> { "tile-grid-item" };
        if (IsOverviewRatingsSection && metric.Key.Equals(TotalClientsMetricKey, StringComparison.Ordinal))
        {
            classes.Add("total-clients-item");
        }

        return string.Join(" ", classes);
    }

    private void HandleTileClick(MetricDto metric)
    {
        ModalService.ShowModal(metric);
    }
}
