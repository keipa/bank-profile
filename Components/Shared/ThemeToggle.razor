@using BankProfiles.Web.Application.Interfaces.Services.Localization
@inject IThemeService ThemeService
@inject IJSRuntime JS
@inject ILogger<ThemeToggle> Logger

<button @onclick="ToggleTheme" 
        class="btn btn-link theme-toggle"
        aria-label="@(_isDark ? "Switch to light mode" : "Switch to dark mode")"
        title="Toggle theme">
    @if (_isDark)
    {
        <i class="fas fa-sun"></i>
    }
    else
    {
        <i class="fas fa-moon"></i>
    }
</button>

@code {
    private bool _isDark;

    protected override void OnInitialized()
    {
        var currentTheme = ThemeService.GetCurrentTheme();
        _isDark = currentTheme == "dark";
    }

    private async Task ToggleTheme()
    {
        var newTheme = _isDark ? "light" : "dark";
        
        try
        {
            await ThemeService.SetThemeAsync(newTheme);

            // Set cookie via JavaScript to avoid "Headers are read-only" error
            // In Blazor Server, event handlers execute after HTTP response is sent
            await JS.InvokeVoidAsync("setCookie", "theme", newTheme, 365);
            
            // Apply theme immediately via JavaScript
            await JS.InvokeVoidAsync("themeHelper.applyTheme", newTheme);
            
            _isDark = !_isDark;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to toggle theme to {Theme}", newTheme);
        }
    }
}
