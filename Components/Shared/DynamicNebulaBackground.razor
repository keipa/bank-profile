@inject Services.IThemeService ThemeService
@implements IDisposable

<div class="nebula-background" style="@GetBackgroundStyle()">
    <div class="nebula-layer nebula-layer-1"></div>
    <div class="nebula-layer nebula-layer-2"></div>
    <div class="nebula-layer nebula-layer-3"></div>
    <div class="nebula-particles"></div>
</div>

<style>
    .nebula-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        overflow: hidden;
        transition: background 1s ease-in-out;
    }

    .nebula-layer {
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        opacity: 0.6;
        mix-blend-mode: screen;
        animation: nebulaFloat 60s ease-in-out infinite;
        will-change: transform;
    }

    .nebula-layer-1 {
        background: radial-gradient(ellipse at 20% 30%, var(--nebula-color-1) 0%, transparent 50%),
                    radial-gradient(ellipse at 80% 70%, var(--nebula-color-2) 0%, transparent 50%),
                    radial-gradient(ellipse at 50% 50%, var(--nebula-color-accent) 0%, transparent 60%);
        animation-name: nebulaFloatCW;
        animation-duration: 80s;
        animation-delay: 0s;
    }

    .nebula-layer-2 {
        background: radial-gradient(ellipse at 60% 20%, var(--nebula-color-2) 0%, transparent 45%),
                    radial-gradient(ellipse at 30% 80%, var(--nebula-color-1) 0%, transparent 45%),
                    radial-gradient(ellipse at 70% 60%, var(--nebula-color-accent) 0%, transparent 55%);
        animation-name: nebulaFloatCCW;
        animation-duration: 100s;
        animation-delay: -25s;
        opacity: 0.5;
    }

    .nebula-layer-3 {
        background: radial-gradient(ellipse at 40% 60%, var(--nebula-color-accent) 0%, transparent 40%),
                    radial-gradient(ellipse at 90% 40%, var(--nebula-color-1) 0%, transparent 50%),
                    radial-gradient(ellipse at 10% 90%, var(--nebula-color-2) 0%, transparent 50%);
        animation-name: nebulaFloatDiagonal;
        animation-duration: 120s;
        animation-delay: -40s;
        opacity: 0.4;
    }

    @@keyframes nebulaFloatCW {
        0%, 100% {
            transform: translate(0, 0) rotate(0deg) scale(1);
        }
        25% {
            transform: translate(15%, -10%) rotate(5deg) scale(1.15);
        }
        50% {
            transform: translate(-8%, 12%) rotate(-3deg) scale(0.85);
        }
        75% {
            transform: translate(-15%, -8%) rotate(4deg) scale(1.08);
        }
    }

    @@keyframes nebulaFloatCCW {
        0%, 100% {
            transform: translate(0, 0) rotate(0deg) scale(1);
        }
        25% {
            transform: translate(-12%, 15%) rotate(-4deg) scale(0.9);
        }
        50% {
            transform: translate(10%, -15%) rotate(6deg) scale(1.12);
        }
        75% {
            transform: translate(12%, 8%) rotate(-5deg) scale(0.92);
        }
    }

    @@keyframes nebulaFloatDiagonal {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(18%, 18%) scale(1.1);
        }
        66% {
            transform: translate(-18%, -18%) scale(0.9);
        }
    }

    /* Mobile optimization - reduce complexity */
    @@media (max-width: 768px) {
        .nebula-layer {
            animation-duration: 30s;
        }
        .nebula-layer-2, .nebula-layer-3 {
            display: none;
        }
        .nebula-particles {
            opacity: 0.3;
        }
    }

    /* Particle/star layer */
    .nebula-particles {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: 
            radial-gradient(2px 2px at 20% 30%, rgba(255, 255, 255, 0.8), transparent),
            radial-gradient(2px 2px at 60% 70%, rgba(255, 255, 255, 0.6), transparent),
            radial-gradient(1px 1px at 50% 50%, rgba(255, 255, 255, 0.9), transparent),
            radial-gradient(2px 2px at 80% 20%, rgba(255, 255, 255, 0.7), transparent),
            radial-gradient(1px 1px at 30% 80%, rgba(255, 255, 255, 0.5), transparent),
            radial-gradient(2px 2px at 90% 60%, rgba(255, 255, 255, 0.6), transparent),
            radial-gradient(1px 1px at 15% 45%, rgba(255, 255, 255, 0.8), transparent),
            radial-gradient(2px 2px at 70% 85%, rgba(255, 255, 255, 0.4), transparent),
            radial-gradient(1px 1px at 40% 15%, rgba(255, 255, 255, 0.7), transparent),
            radial-gradient(2px 2px at 25% 65%, rgba(255, 255, 255, 0.5), transparent);
        background-size: 300px 300px;
        background-position: 0 0, 50px 50px, 100px 100px, 150px 150px, 200px 200px, 
                           250px 250px, 30px 80px, 180px 120px, 220px 40px, 70px 200px;
        animation: twinkle 6s ease-in-out infinite, driftParticles 120s linear infinite;
        pointer-events: none;
        z-index: 10;
    }

    @@keyframes twinkle {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 0.8; }
    }

    @@keyframes driftParticles {
        0% { transform: translate(0, 0); }
        100% { transform: translate(50px, -30px); }
    }

    /* Reduced motion preference */
    @@media (prefers-reduced-motion: reduce) {
        .nebula-layer, .nebula-particles {
            animation: none;
        }
    }
</style>

<script>
    // Performance optimization: pause animations when tab is inactive
    if (typeof document !== 'undefined') {
        document.addEventListener('DOMContentLoaded', function() {
            document.addEventListener('visibilitychange', function() {
                const nebula = document.querySelector('.nebula-background');
                if (nebula) {
                    const layers = nebula.querySelectorAll('.nebula-layer, .nebula-particles');
                    if (document.hidden) {
                        layers.forEach(layer => layer.style.animationPlayState = 'paused');
                    } else {
                        layers.forEach(layer => layer.style.animationPlayState = 'running');
                    }
                }
            });
        });
    }
</script>

@code {
    [Parameter]
    public Models.BankTheme? BankTheme { get; set; }

    private string _currentTheme = "dark";

    protected override void OnInitialized()
    {
        _currentTheme = ThemeService.GetCurrentTheme();
        ThemeService.OnThemeChanged += HandleThemeChange;
    }

    private void HandleThemeChange(string newTheme)
    {
        _currentTheme = newTheme;
        StateHasChanged();
    }

    private string GetBackgroundStyle()
    {
        var colors = GetActiveThemeColors();

        return $@"
            --nebula-color-1: {colors.PrimaryColor};
            --nebula-color-2: {colors.SecondaryColor};
            --nebula-color-accent: {colors.AccentColor};
            background: linear-gradient(135deg, {colors.BackgroundStart} 0%, {colors.BackgroundEnd} 100%);
        ";
    }

    private Models.ThemeColors GetActiveThemeColors()
    {
        if (BankTheme == null)
        {
            // Default fallback colors
            return _currentTheme == "dark"
                ? new Models.ThemeColors
                {
                    PrimaryColor = "#4a90e2",
                    SecondaryColor = "#7b2cbf",
                    AccentColor = "#ff6b9d",
                    BackgroundStart = "#1a1a2e",
                    BackgroundEnd = "#16213e"
                }
                : new Models.ThemeColors
                {
                    PrimaryColor = "#2563eb",
                    SecondaryColor = "#8b5cf6",
                    AccentColor = "#ec4899",
                    BackgroundStart = "#f0f9ff",
                    BackgroundEnd = "#e0f2fe"
                };
        }

        // Return bank-specific theme colors
        var themeColors = _currentTheme == "dark" ? BankTheme.DarkTheme : BankTheme.LightTheme;

        if (themeColors != null)
        {
            return themeColors;
        }

        // Fallback to legacy single theme if dual theme not available
        return new Models.ThemeColors
        {
            PrimaryColor = BankTheme.PrimaryColor ?? "#4a90e2",
            SecondaryColor = BankTheme.SecondaryColor ?? "#7b2cbf",
            AccentColor = BankTheme.AccentColor ?? "#ff6b9d",
            BackgroundStart = _currentTheme == "dark" ? "#1a1a2e" : "#f0f9ff",
            BackgroundEnd = _currentTheme == "dark" ? "#16213e" : "#e0f2fe"
        };
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= HandleThemeChange;
    }
}
