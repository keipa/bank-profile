@* Skeleton loader for BankDetail page *@
<div class="bank-detail-container">
    @* Breadcrumb Skeleton *@
    <nav aria-label="breadcrumb" class="mb-3" style="position: relative; z-index: 10;">
        <div class="skeleton skeleton-text" style="width: 400px; height: 1.5em;"></div>
    </nav>

    @* Credit Card Skeleton *@
    <div class="center-section">
        <div class="skeleton skeleton-credit-card"></div>
    </div>

    @* Glass Grid Skeleton *@
    <div class="glass-grid">
        <div class="skeleton-glass-window">
            <div class="skeleton skeleton-text-xl" style="width: 150px; margin-bottom: 1rem;"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text" style="width: 80%;"></div>
        </div>

        <div class="skeleton-glass-window">
            <div class="skeleton skeleton-text-xl" style="width: 180px; margin-bottom: 1rem;"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text" style="width: 70%;"></div>
        </div>

        <div class="skeleton-glass-window">
            <div class="skeleton skeleton-text-xl" style="width: 160px; margin-bottom: 1rem;"></div>
            <div class="skeleton skeleton-chart-body"></div>
        </div>

        <div class="skeleton-glass-window">
            <div class="skeleton skeleton-text-xl" style="width: 140px; margin-bottom: 1rem;"></div>
            <div class="skeleton skeleton-chart-body"></div>
        </div>

        <div class="skeleton-glass-window" style="height: 200px;">
            <div class="skeleton skeleton-text-xl" style="width: 120px; margin-bottom: 1rem;"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text" style="width: 60%;"></div>
        </div>

        <div class="skeleton-glass-window" style="height: 200px;">
            <div class="skeleton skeleton-text-xl" style="width: 140px; margin-bottom: 1rem;"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text" style="width: 80%;"></div>
        </div>
    </div>
</div>
