@using BankProfiles.Web.Application.Interfaces.Services.Ratings
@using PSC.Blazor.Components.Chartjs
@using PSC.Blazor.Components.Chartjs.Models.Line
@inject IChartDataService ChartDataService
@inject ILogger<RatingChart> Logger

<div class="rating-chart">
    <div class="chart-header">
        <h3 id="rating-chart-title">Rating Trends</h3>
        <div class="chart-controls" role="group" aria-labelledby="rating-chart-title">
            <button class="@GetButtonClass(30)" @onclick="() => SetTimeRange(30)" aria-label="Show rating trends for last 30 days" aria-pressed="@(TimeRange == 30)">30 Days</button>
            <button class="@GetButtonClass(90)" @onclick="() => SetTimeRange(90)" aria-label="Show rating trends for last 90 days" aria-pressed="@(TimeRange == 90)">90 Days</button>
            <button class="@GetButtonClass(365)" @onclick="() => SetTimeRange(365)" aria-label="Show rating trends for last 365 days" aria-pressed="@(TimeRange == 365)">1 Year</button>
        </div>
    </div>
    
    @if (_isLoading)
    {
        <div role="status" aria-label="Loading rating chart">
            <span class="visually-hidden">Loading rating chart data...</span>
            <ChartSkeleton />
        </div>
    }
    else if (_chartConfig != null)
    {
        <div class="chart-container fade-in" style="height: 400px;" role="img" aria-label="Line chart showing rating trends over time for different criteria">
            <Chart @ref="_chartComponent" Config="_chartConfig" Width="600" Height="400" />
        </div>
    }
    else
    {
        <div class="chart-empty" role="status">
            <p>No rating history available for this bank.</p>
        </div>
    }
</div>

@code {
    [Parameter]
    public string BankCode { get; set; } = string.Empty;

    [Parameter]
    public int TimeRange { get; set; } = 30;

    private LineChartConfig? _chartConfig;
    private Chart? _chartComponent;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadChartData();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadChartData();
    }

    private async Task SetTimeRange(int days)
    {
        if (TimeRange != days)
        {
            TimeRange = days;
            await LoadChartData();
        }
    }

    private string GetButtonClass(int days)
    {
        return TimeRange == days ? "time-btn active" : "time-btn";
    }

    private async Task LoadChartData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var chartDataSets = await ChartDataService.GetRatingHistoryByCriteriaAsync(BankCode, TimeRange);
            if (chartDataSets.Count == 0)
            {
                _chartConfig = null;
                _isLoading = false;
                return;
            }

            _chartConfig = new LineChartConfig();
            foreach (var date in chartDataSets[0].Labels)
            {
                _chartConfig.Data.Labels.Add(date);
            }

            foreach (var criteriaDataSet in chartDataSets)
            {
                var dataset = new LineDataset()
                {
                    Label = criteriaDataSet.Label,
                    Data = criteriaDataSet.Data,
                    BackgroundColor = criteriaDataSet.BackgroundColor,
                    BorderColor = criteriaDataSet.BorderColor,
                    BorderWidth = 2,
                    Fill = false,
                    PointRadius = 3,
                    Tension = 0.4m
                };

                _chartConfig.Data.Datasets.Add(dataset);
            }

            if (!_chartConfig.Data.Datasets.Any())
            {
                _chartConfig = null;
            }
        }
        catch (ObjectDisposedException)
        {
            Logger.LogDebug("Rating chart component disposed while loading data for {BankCode}", BankCode);
            _chartConfig = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load rating chart data for {BankCode} and range {TimeRange}", BankCode, TimeRange);
            _chartConfig = null;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
