{
  "ConnectionStrings": {
    "BankDatabase": "Server=(localdb)\\mssqllocaldb;Database=BankProfiles;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;Max Pool Size=512;Min Pool Size=10"
  },
  "CacheSettings": {
    "SizeLimitMB": 500,
    "AbsoluteExpirationMinutes": 60,
    "EnableSizeLimit": true
  },
  "BankDataSettings": {
    "DataDirectory": "wwwroot/data/banks",
    "AutoRefreshEnabled": false,
    "RefreshIntervalMinutes": 1440
  },
  "RatingSettings": {
    "MinRating": 0,
    "MaxRating": 10,
    "EnableHistory": true,
    "HistorySnapshotIntervalHours": 24
  },
  "SignalRSettings": {
    "MaxCircuitsPerIP": 5,
    "DisconnectedCircuitMaxRetained": 100,
    "DisconnectedCircuitRetentionPeriod": "00:03:00",
    "JSInteropDefaultCallTimeout": "00:01:00",
    "MaximumReceiveMessageSize": 131072
  },
  "RateLimitSettings": {
    "PermitLimit": 300,
    "WindowSeconds": 60,
    "QueueLimit": 0,
    "AutoReplenishment": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "BankProfiles.Web.Middleware.CircuitRateLimitingMiddleware": "Information",
      "Program": "Warning"
    }
  },
  "AllowedHosts": "*"
}
