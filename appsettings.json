{
  "ConnectionStrings": {
    "BankDatabase": "Server=(localdb)\\mssqllocaldb;Database=BankProfiles;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "CacheSettings": {
    "SizeLimitMB": 500,
    "AbsoluteExpirationMinutes": 60,
    "EnableSizeLimit": true
  },
  "BankDataSettings": {
    "DataDirectory": "wwwroot/data/banks",
    "AutoRefreshEnabled": false,
    "RefreshIntervalMinutes": 1440
  },
  "RatingSettings": {
    "MinRating": 0,
    "MaxRating": 10,
    "EnableHistory": true,
    "HistorySnapshotIntervalHours": 24
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
